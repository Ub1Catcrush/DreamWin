<UserControl x:Class="DreamWin.Views.EpgView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DreamWin.Views"
             Background="{StaticResource BgDeep}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0">
                    <TextBlock Text="EPG Guide" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding CurrentServiceName}" FontSize="12"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <TextBox Grid.Column="1" Grid.Row="0" Style="{StaticResource DarkTextBox}"
                         Width="220" Margin="0,0,8,0" VerticalAlignment="Center"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Grid.Row="0" Style="{StaticResource AccentButton}"
                        Content="Search EPG" Padding="14,8" Margin="0,0,8,0"
                        Command="{Binding SearchCommand}"/>

                <!-- List / Grid toggle -->
                <StackPanel Grid.Column="3" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Padding="10,6" Margin="0,0,4,0" Command="{Binding ToggleGridViewCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGridView}" Value="False">
                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="≡ List"/>
                    </Button>
                    <Button Padding="10,6" Command="{Binding ToggleGridViewCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGridView}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="⊞ Grid"/>
                    </Button>
                </StackPanel>

                <!-- Row 2: Bouquet tabs + navigation -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,10,0,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" Height="32">
                        <ItemsControl ItemsSource="{Binding Bouquets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,4,0" Padding="12,5"
                                            Content="{Binding ServiceName}"
                                            Command="{Binding DataContext.SelectBouquetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource EpgTabButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                                <Binding Path="."/>
                                                                <Binding Path="DataContext.SelectedBouquet"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- List mode: channel picker + day navigation -->
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                                Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibilityInverted}}">
                        <ComboBox Width="200" Margin="0,0,8,0" Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding Services}" SelectedItem="{Binding SelectedService}"
                                  DisplayMemberPath="ServiceName"/>
                        <Button Style="{StaticResource AccentButton}" Padding="10,5" Margin="0,0,4,0"
                                Content="Today" Command="{Binding ListDayTodayCommand}"/>
                        <Button Style="{StaticResource BaseButton}" Padding="10,5" Margin="0,0,8,0"
                                Content="Tomorrow ▶" Command="{Binding ListDayForwardCommand}"/>
                        <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondary}"
                                   Text="{Binding ListDay, StringFormat='{}{0:dddd\, dd. MMMM yyyy}'}"/>
                    </StackPanel>

                    <!-- Grid mode: orientation toggle + 7-day quick picker -->
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                                Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibility}}">

                        <!-- Layout orientation toggle -->
                        <Button Padding="9,5" Margin="0,0,8,0"
                                Command="{Binding ToggleGridOrientationCommand}"
                                ToolTip="Toggle between channels on X-axis (horizontal) or Y-axis (vertical)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                    <Setter Property="Content" Value="↔ H-Layout"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGridHorizontal}" Value="False">
                                            <Setter Property="Content" Value="↕ V-Layout"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="0,3,8,3"/>

                        <!-- 7-day quick picker: Today + 6 days ahead, wired via code-behind Click -->
                        <Button Style="{StaticResource BaseButton}" Padding="8,5" Margin="0,0,3,0"
                                Content="◀" Command="{Binding GridStepBackCommand}" ToolTip="Previous day"/>
                        <ItemsControl x:Name="DayPickerPanel" ItemsSource="{Binding DayPickerDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,3,0" Padding="10,5"
                                            Content="{Binding Label}"
                                            Tag="{Binding Offset}"
                                            Click="DayPickerButton_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource EpgTabButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                                <Binding Path="Offset"/>
                                                                <Binding Path="DataContext.GridDayOffset"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Style="{StaticResource BaseButton}" Padding="8,5"
                                Content="▶" Command="{Binding GridStepForwardCommand}" ToolTip="Next day"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── LIST VIEW ── -->
        <Grid Grid.Row="1" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibilityInverted}}">
            <!-- Loading overlay — prevents stale/previous-day events from being
                 visible while the new day's data is being fetched -->
            <Border Background="#CC000000" Panel.ZIndex="10"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Margin="12,12,12,0" Padding="12,8" CornerRadius="6"
                            Background="#332E3A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentRed}"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource BaseButton}" Padding="8,4" Margin="8,0,0,0"
                                    Content="↺ Retry" Command="{Binding RetryCommand}"/>
                        </StackPanel>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Events}" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="8" Cursor="Hand"
                                        Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ShowEpgDetailCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentlyAiring}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="14,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TimeRange}" FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource Accent}"/>
                                            <TextBlock Text="{Binding Duration}" FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                                        Visibility="{Binding IsCurrentlyAiring,
                                                                     Converter={StaticResource BoolToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#EF4444" Opacity="0.2"/>
                                                    </Border.Background>
                                                    <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentRed}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ShortDesc}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                                Content="+ Timer" Padding="10,6" FontSize="11"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RequestAddTimerCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Empty list state: only shown when not loading AND no events present,
             so it never flashes "Select a channel" while EPG data is being fetched -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibilityInverted}}">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasListEvents}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="📅" FontSize="56" HorizontalAlignment="Center" Opacity="0.2"/>
            <TextBlock Text="Select a channel to view its EPG"
                       Foreground="{StaticResource TextMuted}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════════════
             GRID VIEW  —  two layouts selectable via IsGridHorizontal toggle

             HORIZONTAL (default, IsGridHorizontal=True):
               Channels = columns (X axis, 180px each)
               Time     = rows    (Y axis, 54px per 30min slot)
               Scroll   = up/down for time, left/right for channels

             VERTICAL (IsGridHorizontal=False):
               Channels = rows    (Y axis, 54px each)
               Time     = columns (X axis, 180px per 30min slot)
               Scroll   = left/right for time, up/down for channels
        ════════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGridView, Converter={StaticResource BoolToVisibility}}">

            <!-- Loading overlay (shared by both orientations) -->
            <Border Background="#CC000000" Panel.ZIndex="20"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- ── HORIZONTAL layout (channels=X, time=Y) ─────────────────────── -->
            <Grid Visibility="{Binding IsGridHorizontal, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>  <!-- Frozen channel-name headers -->
                    <RowDefinition Height="*"/>   <!-- Scrollable body -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/> <!-- Frozen time-axis -->
                    <ColumnDefinition Width="*"/>  <!-- Scrollable channel columns -->
                </Grid.ColumnDefinitions>

                <!-- Top-left corner -->
                <Border Grid.Row="0" Grid.Column="0" Panel.ZIndex="10"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1">
                    <TextBlock Text="Time" FontSize="10" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Channel headers (frozen top row, h-scroll synced) -->
                <ScrollViewer Grid.Row="0" Grid.Column="1"
                              x:Name="HeaderScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Panel.ZIndex="10" IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding GridRows}" HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="180" Height="52"
                                        Background="{StaticResource BgPanel}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                        <Border Width="32" Height="32" Margin="0,0,6,0"
                                                CornerRadius="4" Background="{StaticResource BgCard}">
                                            <Image Width="30" Height="30" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource PiconUrl}"
                                                                  TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                        <Binding Path="Service.ServiceReference"/>
                                                        <Binding Path="DataContext.ActiveReceiver"
                                                                 RelativeSource="{RelativeSource AncestorType={x:Type views:MainWindow}}"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <TextBlock Text="{Binding Service.ServiceName}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="128"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Time axis (frozen left column, v-scroll synced) -->
                <ScrollViewer Grid.Row="1" Grid.Column="0"
                              x:Name="TimeScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Hidden"
                              Panel.ZIndex="10" IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding GridTimeSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="54" Background="{StaticResource BgPanel}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1">
                                    <TextBlock Text="{Binding}" FontSize="10"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="4,4,4,0" VerticalAlignment="Top"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Master scroll: event canvases -->
                <ScrollViewer Grid.Row="1" Grid.Column="1"
                              x:Name="EventScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="EventScrollViewer_ScrollChanged"
                              PreviewMouseDown="EventScrollViewer_PreviewMouseDown"
                              PreviewMouseMove="EventScrollViewer_PreviewMouseMove"
                              PreviewMouseUp="EventScrollViewer_PreviewMouseUp"
                              LostMouseCapture="ScrollViewer_LostMouseCapture"
                              Cursor="Arrow">
                    <ItemsControl ItemsSource="{Binding GridRows}"
                                  HorizontalAlignment="Left" VerticalAlignment="Top">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Channel column: 180px wide, full-day height -->
                                <Canvas Width="180"
                                        Height="{Binding DataContext.GridTotalHeight,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        ClipToBounds="True">
                                    <Rectangle Canvas.Left="179" Canvas.Top="0" Width="1"
                                               Height="{Binding DataContext.GridTotalHeight,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Fill="{StaticResource BorderBrush}"/>
                                    <!-- Now line (horizontal red rule) -->
                                    <Rectangle Canvas.Left="0" Width="178" Height="2"
                                               Fill="{StaticResource AccentRed}" Panel.ZIndex="5"
                                               Canvas.Top="{Binding DataContext.NowLineY,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <ItemsControl ItemsSource="{Binding Events}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="180"
                                                        Height="{Binding DataContext.GridTotalHeight,
                                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Top"  Value="{Binding OffsetPx}"/>
                                                <Setter Property="Canvas.Left" Value="1"/>
                                                <Setter Property="Width"       Value="177"/>
                                                <Setter Property="Height"      Value="{Binding HeightPx}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,1" CornerRadius="3" ClipToBounds="True"
                                                        BorderThickness="1" Cursor="Hand"
                                                        MouseLeftButtonUp="EventBorder_MouseLeftButtonUp">
                                                    <Border.ToolTip>
                                                        <StackPanel MaxWidth="280">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding TimeRange}" Foreground="{StaticResource Accent}" Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding ShortDesc}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Border.ToolTip>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentlyAiring}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                                    <Setter Property="BorderBrush"  Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Margin="4,3" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="Medium"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding TimeRange}" FontSize="9"
                                                                   Foreground="{StaticResource TextMuted}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── VERTICAL layout (channels=Y rows, time=X columns) ───────────── -->
            <Grid Visibility="{Binding IsGridHorizontal, Converter={StaticResource BoolToVisibilityInverted}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>  <!-- Frozen time-slot header row -->
                    <RowDefinition Height="*"/>   <!-- Scrollable channel rows -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/> <!-- Frozen channel-name column -->
                    <ColumnDefinition Width="*"/>   <!-- Scrollable time columns -->
                </Grid.ColumnDefinitions>

                <!-- Top-left corner -->
                <Border Grid.Row="0" Grid.Column="0" Panel.ZIndex="10"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1">
                    <TextBlock Text="Channel" FontSize="10" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Time-slot headers (frozen top row, h-scroll synced) -->
                <ScrollViewer Grid.Row="0" Grid.Column="1"
                              x:Name="VHeaderScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Panel.ZIndex="10" IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding GridTimeSlots}" HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="180" Height="52"
                                        Background="{StaticResource BgPanel}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1">
                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="Medium"
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Channel name column (frozen left, v-scroll synced) -->
                <ScrollViewer Grid.Row="1" Grid.Column="0"
                              x:Name="VChannelScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Hidden"
                              Panel.ZIndex="10" IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding GridRows}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="54" Width="180"
                                        Background="{StaticResource BgPanel}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,1,1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                        <Border Width="28" Height="28" Margin="0,0,6,0"
                                                CornerRadius="4" Background="{StaticResource BgCard}">
                                            <Image Width="26" Height="26" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource PiconUrl}"
                                                                  TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                        <Binding Path="Service.ServiceReference"/>
                                                        <Binding Path="DataContext.ActiveReceiver"
                                                                 RelativeSource="{RelativeSource AncestorType={x:Type views:MainWindow}}"/>
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <TextBlock Text="{Binding Service.ServiceName}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Master scroll: channel rows with horizontal time canvases -->
                <ScrollViewer Grid.Row="1" Grid.Column="1"
                              x:Name="VEventScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="VEventScrollViewer_ScrollChanged"
                              PreviewMouseDown="VEventScrollViewer_PreviewMouseDown"
                              PreviewMouseMove="VEventScrollViewer_PreviewMouseMove"
                              PreviewMouseUp="VEventScrollViewer_PreviewMouseUp"
                              LostMouseCapture="ScrollViewer_LostMouseCapture"
                              Cursor="Arrow">
                    <ItemsControl ItemsSource="{Binding GridRows}"
                                  HorizontalAlignment="Left" VerticalAlignment="Top">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Channel row: full-day width, 54px tall -->
                                <Canvas Height="54"
                                        Width="{Binding DataContext.GridTotalHeight,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        ClipToBounds="True">
                                    <!-- Bottom border rule -->
                                    <Rectangle Canvas.Left="0" Canvas.Top="53"
                                               Width="{Binding DataContext.GridTotalHeight,
                                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               Height="1" Fill="{StaticResource BorderBrush}"/>
                                    <!-- Now line (vertical red rule) -->
                                    <Rectangle Canvas.Top="0" Height="54" Width="2"
                                               Fill="{StaticResource AccentRed}" Panel.ZIndex="5"
                                               Canvas.Left="{Binding DataContext.NowLineY,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <!-- Event blocks: placed horizontally by OffsetPx → Canvas.Left -->
                                    <ItemsControl ItemsSource="{Binding Events}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Height="54"
                                                        Width="{Binding DataContext.GridTotalHeight,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left"   Value="{Binding OffsetPx}"/>
                                                <Setter Property="Canvas.Top"    Value="1"/>
                                                <Setter Property="Width"         Value="{Binding HeightPx}"/>
                                                <Setter Property="Height"        Value="52"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="1,0" CornerRadius="3" ClipToBounds="True"
                                                        BorderThickness="1" Cursor="Hand"
                                                        MouseLeftButtonUp="EventBorder_MouseLeftButtonUp">
                                                    <Border.ToolTip>
                                                        <StackPanel MaxWidth="280">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding TimeRange}" Foreground="{StaticResource Accent}" Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding ShortDesc}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Border.ToolTip>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentlyAiring}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                                    <Setter Property="BorderBrush"  Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Margin="4,3" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="Medium"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding TimeRange}" FontSize="9"
                                                                   Foreground="{StaticResource TextMuted}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
        <!-- EPG Detail Popup — modal overlay shown on click of any event block or list item.
             Clicking the dark background dismisses it. -->
        <Grid Grid.RowSpan="2"
              Visibility="{Binding SelectedEventDetail, Converter={StaticResource NullToVisibility}}"
              Background="#CC000000" Panel.ZIndex="100">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseEpgDetailCommand}"/>
            </Grid.InputBindings>
            <Border MaxWidth="560" MaxHeight="500" CornerRadius="12" Margin="24"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title + close -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SelectedEventDetail.Title}" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"
                                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,36,0"/>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Style="{StaticResource BaseButton}" Padding="8,4" FontSize="14"
                                Content="✕" Command="{Binding CloseEpgDetailCommand}"/>
                    </Grid>

                    <!-- Time / channel info -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Background="{StaticResource Accent}" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="{Binding SelectedEventDetail.TimeRange}" FontSize="12"
                                       Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <Border Background="{StaticResource BgHover}" CornerRadius="4" Padding="8,3"
                                Visibility="{Binding SelectedEventDetail.Duration, Converter={StaticResource NullToVisibility}}">
                            <TextBlock Text="{Binding SelectedEventDetail.Duration}" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                    </StackPanel>

                    <!-- Description -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                        <TextBlock Text="{Binding SelectedEventDetail.LongDesc}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12.5"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </ScrollViewer>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Style="{StaticResource BaseButton}" Padding="14,7" Margin="0,0,8,0"
                                Content="Close" Command="{Binding CloseEpgDetailCommand}"/>
                        <Button Style="{StaticResource AccentButton}" Padding="14,7"
                                Content="+ Add Timer"
                                Command="{Binding RequestAddTimerCommand}"
                                CommandParameter="{Binding SelectedEventDetail}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>