<UserControl x:Class="DreamWin.Views.EpgView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeep}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Search -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="EPG Guide" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding CurrentServiceName}" FontSize="12"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}"
                         Width="240" Margin="0,0,8,0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                        Content="Search EPG" Padding="14,8"
                        Command="{Binding SearchCommand}"/>
            </Grid>
        </Border>

        <!-- EPG Event List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Error banner: surfaces load failures that would otherwise just leave
                     the EPG list looking silently empty. -->
                <Border Margin="12,12,12,0" Padding="12,8" CornerRadius="6"
                        Background="#332E3A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentRed}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Events}" Padding="12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" CornerRadius="8"
                                Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentlyAiring}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Time -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TimeRange}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="{Binding Duration}"
                                               FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>

                                <!-- Content -->
                                <StackPanel Grid.Column="1" Margin="12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                                Visibility="{Binding IsCurrentlyAiring, Converter={StaticResource BoolToVisibility}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="#EF4444" Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentRed}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ServiceName}"
                                               FontSize="11" Foreground="{StaticResource Accent}"
                                               Margin="0,1,0,0"
                                               Visibility="{Binding ServiceName, Converter={StaticResource NullToVisibility}}"/>
                                    <TextBlock Text="{Binding ShortDesc}"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                    <!-- Progress bar for current -->
                                    <Border Height="2" Background="{StaticResource BgPanel}" CornerRadius="1"
                                            Margin="0,6,0,0"
                                            Visibility="{Binding IsCurrentlyAiring, Converter={StaticResource BoolToVisibility}}">
                                        <Border HorizontalAlignment="Left" Background="{StaticResource Accent}"
                                                CornerRadius="1">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource ProgressToWidth}">
                                                    <Binding Path="ProgressPercent"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </StackPanel>

                                <!-- Add Timer Button -->
                                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                        Content="+ Timer" Padding="10,6" FontSize="11" VerticalAlignment="Center"
                                        Command="{Binding DataContext.RequestAddTimerCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Events.Count, Converter={StaticResource NullToVisibility}}">
            <TextBlock Text="📅" FontSize="56" HorizontalAlignment="Center" Opacity="0.2"/>
            <TextBlock Text="Select a channel from Live TV to view the EPG"
                       Foreground="{StaticResource TextMuted}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="or use the search box above"
                       Foreground="{StaticResource TextMuted}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
