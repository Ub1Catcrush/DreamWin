<UserControl x:Class="DreamWin.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DreamWin"
             xmlns:models="clr-namespace:DreamWin.Models"
             xmlns:svc="clr-namespace:DreamWin.Services"
             Background="{StaticResource BgDeep}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700" HorizontalAlignment="Left" Margin="24,20">

            <!-- Title -->
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="Manage your Enigma2 receivers and preferences"
                       FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,24"/>

            <!-- Receivers Section -->
            <TextBlock Text="RECEIVERS" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Receiver list -->
                    <ItemsControl ItemsSource="{Binding Receivers}" x:Name="ReceiverList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource TextMuted}"/>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                                <Run Text="{Binding Host}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Port}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Style="{StaticResource BaseButton}" Margin="0,0,6,0"
                                                    Padding="10,5" FontSize="11" Content="Edit"
                                                    Click="EditReceiverClick" Tag="{Binding}"/>
                                            <Button Style="{StaticResource AccentButton}"
                                                    Padding="10,5" FontSize="11" Content="Connect"
                                                    Click="ConnectReceiverClick" Tag="{Binding}"/>
                                            <Button Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                                                    Padding="10,5" FontSize="11" Content="Remove"
                                                    Click="RemoveReceiverClick" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add Receiver button -->
                    <Button Style="{StaticResource BaseButton}" HorizontalAlignment="Left"
                            Margin="16,10" Padding="14,8" Content="+ Add Receiver"
                            Click="AddReceiverClick"/>
                </StackPanel>
            </Border>

            <!-- Add/Edit Receiver Form (shown inline) -->
            <Border x:Name="ReceiverForm" Visibility="Collapsed"
                    Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource Accent}" BorderThickness="1" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Add Receiver" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,12">
                            <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FieldName" Style="{StaticResource DarkTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,12">
                            <TextBlock Text="Host / IP" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FieldHost" Style="{StaticResource DarkTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,12">
                            <TextBlock Text="Web Port" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FieldPort" Style="{StaticResource DarkTextBox}" Text="80"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,0,0,12">
                            <TextBlock Text="Stream Port" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FieldStreamPort" Style="{StaticResource DarkTextBox}" Text="8001"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,8,12">
                            <TextBlock Text="Username (optional)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FieldUsername" Style="{StaticResource DarkTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2" Margin="8,0,0,12">
                            <TextBlock Text="Password (optional)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="FieldPassword"
                                         Background="{StaticResource BgCard}"
                                         Foreground="{StaticResource TextPrimary}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1" Padding="8,6"/>
                        </StackPanel>
                    </Grid>

                    <!-- HTTPS options -->
                    <StackPanel Margin="0,4,0,12">
                        <CheckBox x:Name="FieldUseHttps" Content="Use HTTPS for web API"
                                  Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="FieldAcceptSelfSigned"
                                      Content="Accept self-signed certificate"
                                      Foreground="{StaticResource TextSecondary}"/>
                            <Border Background="#2D2016" BorderBrush="#F97316" BorderThickness="1"
                                    CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding IsChecked, ElementName=FieldAcceptSelfSigned,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="⚠ Certificate validation disabled"
                                           FontSize="10" Foreground="#F97316"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BaseButton}" Padding="14,8" Margin="0,0,8,0"
                                Content="Cancel" Click="CancelFormClick"/>
                        <Button Style="{StaticResource AccentButton}" Padding="14,8"
                                Content="Save Receiver" Click="SaveReceiverClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Color Scheme Section -->
            <TextBlock Text="COLOR SCHEME" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,24,0,8"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Theme presets" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🟣 Purple" Click="ThemePresetClick" Tag="Purple (Default)"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🩵 Teal" Click="ThemePresetClick" Tag="Teal"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🟠 Orange" Click="ThemePresetClick" Tag="Orange"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🌹 Rose" Click="ThemePresetClick" Tag="Rose"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🔵 Sky Blue" Click="ThemePresetClick" Tag="Sky Blue"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🟢 Emerald" Click="ThemePresetClick" Tag="Emerald"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="🟡 Amber" Click="ThemePresetClick" Tag="Amber"/>
                        <Button Style="{StaticResource BaseButton}" Margin="0,0,6,6" Padding="10,6"
                                Content="☀ Light" Click="ThemePresetClick" Tag="Light"/>
                    </WrapPanel>

                    <TextBlock Text="Custom accent color (hex, e.g. #6C63FF)" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AccentColorInput" Grid.Column="0"
                                 Text="{Binding AccentColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"/>
                        <Button Grid.Column="2" Style="{StaticResource AccentButton}" Padding="12,6"
                                Content="Apply" Click="ApplyCustomAccentClick"/>
                    </Grid>

                    <!-- Live preview swatch -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Current accent: " FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <Border Width="20" Height="20" CornerRadius="4" Background="{StaticResource Accent}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Language Section -->
            <TextBlock Text="{Binding [Settings_Language], Source={x:Static svc:Loc.Instance}}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding [Settings_Language], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding [Settings_Language_Desc], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" VerticalAlignment="Center"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{x:Static svc:LocalizationService.SupportedLanguages}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.Language, Mode=TwoWay}"
                              SelectionChanged="LanguageChanged"/>
                </Grid>
            </Border>

            <!-- VLC Playback Section -->
            <TextBlock Text="VLC PLAYBACK" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,24,0,8"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14" Margin="0,0,0,4">
                <StackPanel>

                    <TextBlock Text="Changes take effect after restarting playback (channel switch or re-open)."
                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,14"
                               TextWrapping="Wrap"/>

                    <!-- Video Output -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Video Output" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Rendering backend" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectedValue="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcVideoOutput, Mode=TwoWay}" SelectedValuePath="Tag"
                                  SelectionChanged="VlcSettingChanged">
                            <ComboBoxItem Content="Auto (recommended)" Tag="auto"/>
                            <ComboBoxItem Content="Direct3D 11" Tag="direct3d11"/>
                            <ComboBoxItem Content="OpenGL" Tag="opengl"/>
                            <ComboBoxItem Content="DirectDraw (legacy)" Tag="directdraw"/>
                        </ComboBox>
                    </Grid>

                    <!-- Hardware Acceleration -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Hardware Acceleration" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="GPU-accelerated decoding" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcHardwareAcceleration, Mode=TwoWay}"
                                  Checked="VlcSettingChanged" Unchecked="VlcSettingChanged">
                            <TextBlock Text="Enable (avcodec-hw=any)" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </CheckBox>
                    </Grid>

                    <!-- Network Cache -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Network Cache" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Live TV / IPTV buffer" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcNetworkCacheMs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="VlcSettingChanged"/>
                        <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" FontSize="12"/>
                    </Grid>

                    <!-- File Cache -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="File Cache" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Recordings playback buffer" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcFileCacheMs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="VlcSettingChanged"/>
                        <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" FontSize="12"/>
                    </Grid>

                    <!-- TS Seek Accuracy (recordings only) -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="TS Seek Accuracy" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Recording seek mitigation — try toggling if seeking stutters" FontSize="10"
                                       Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcTsSeekOptions, Mode=TwoWay}"
                                  Checked="VlcSettingChanged" Unchecked="VlcSettingChanged">
                            <TextBlock Text="Enable (no-ts-trust-pcr + ts-seek-percent)" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </CheckBox>
                    </Grid>

                    <!-- Deinterlace -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Deinterlace" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="For interlaced broadcast content" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectedValue="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcDeinterlace, Mode=TwoWay}" SelectedValuePath="Tag"
                                  SelectionChanged="VlcSettingChanged">
                            <ComboBoxItem Content="Auto" Tag="auto"/>
                            <ComboBoxItem Content="On" Tag="on"/>
                            <ComboBoxItem Content="Off" Tag="off"/>
                        </ComboBox>
                    </Grid>

                    <!-- Deinterlace Mode -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Deinterlace Mode" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Algorithm (when deinterlace ≠ Off)" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectedValue="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.VlcDeinterlaceMode, Mode=TwoWay}" SelectedValuePath="Tag"
                                  SelectionChanged="VlcSettingChanged">
                            <ComboBoxItem Content="Blend (default, fast)" Tag="blend"/>
                            <ComboBoxItem Content="Bob" Tag="bob"/>
                            <ComboBoxItem Content="Linear" Tag="linear"/>
                            <ComboBoxItem Content="Mean" Tag="mean"/>
                            <ComboBoxItem Content="Discard" Tag="discard"/>
                            <ComboBoxItem Content="Yadif" Tag="yadif"/>
                            <ComboBoxItem Content="Yadif 2x (best quality)" Tag="yadif2x"/>
                            <ComboBoxItem Content="Phosphor" Tag="phosphor"/>
                            <ComboBoxItem Content="IVTC (film)" Tag="ivtc"/>
                        </ComboBox>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Updates Section -->
            <TextBlock Text="UPDATES" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,24,0,8"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14">
                <StackPanel>
                    <!-- Check for updates button -->
                    <Button Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,0,12"
                            Content="Check for Updates"
                            Command="{Binding CheckForUpdatesCommand}"/>

                    <!-- Update status message -->
                    <TextBlock Text="{Binding UpdateStatus}" FontSize="12" 
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- Install update button (shown when update available) -->
                    <Button Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,0,12"
                            Content="Install Update" Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding InstallUpdateCommand}"/>

                    <!-- Update preferences -->
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox IsChecked="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.CheckForUpdates, Mode=TwoWay}"
                                      VerticalAlignment="Center" Margin="0,0,8,0"
                                      Checked="UpdateSettingChanged" Unchecked="UpdateSettingChanged"/>
                            <TextBlock Text="Check for updates automatically" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <CheckBox IsChecked="{Binding Source={x:Static local:App.SettingsService}, Path=Settings.IncludePrereleases, Mode=TwoWay}"
                                      VerticalAlignment="Center" Margin="0,0,8,0"
                                      Checked="UpdateSettingChanged" Unchecked="UpdateSettingChanged"/>
                            <TextBlock Text="Include pre-release versions" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,24,0,8"/>
            <Border Background="{StaticResource BgPanel}" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,14">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                        <Run Text="DreamWin"/>
                        <Run Text="{Binding Source={x:Static local:App.UpdateService}, Path=CurrentVersion, StringFormat='v{0}', Mode=OneWay}" Foreground="{StaticResource Accent}"/>
                    </TextBlock>
                    <TextBlock Text="Windows client for Enigma2 satellite receivers (OpenWebif)"
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    <TextBlock Text="Compatible with DreamBox, VU+, Xtrend, Gigablue and all Enigma2 receivers"
                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
