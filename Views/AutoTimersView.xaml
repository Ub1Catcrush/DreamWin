<UserControl x:Class="DreamWin.Views.AutoTimersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DreamWin.Controls"
             Background="{StaticResource BgDeep}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="AutoTimers" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding AutoTimers.Count, StringFormat='{}{0} rules configured'}"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource BaseButton}" Padding="12,8" Margin="0,0,8,0"
                            Content="▶ Parse EPG" Command="{Binding ParseEpgCommand}"
                            ToolTip="Run AutoTimer against EPG now"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource BaseButton}" Padding="12,8" Margin="0,0,8,0"
                            Content="↺ Refresh" Command="{Binding LoadCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource AccentButton}" Padding="14,8"
                            Content="+ New AutoTimer" Command="{Binding NewAutoTimerCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="420" x:Name="EditPanelColumn"/>
            </Grid.ColumnDefinitions>

            <!-- AutoTimer List -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Error banner -->
                    <Border Margin="12,12,12,0" Padding="12,8" CornerRadius="6"
                            Background="#332E3A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentRed}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Plugin not available notice -->
                    <Border Margin="12,12,12,0" Padding="12,10" CornerRadius="6"
                            Background="#1A1D27" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Visibility="{Binding PluginAvailable, Converter={StaticResource BoolToVisibilityInverted}}">
                        <StackPanel>
                            <TextBlock Text="AutoTimer plugin not detected" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="Install the AutoTimer plugin on your Enigma2 receiver to use this feature."
                                       FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding AutoTimers}" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="8"
                                        Background="{StaticResource BgCard}"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BorderBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.SelectedAutoTimer"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="14,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Enabled indicator -->
                                        <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1E40AF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                    <Setter Property="Background" Value="#374151"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="9" FontWeight="Bold" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ON"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                        <Setter Property="Text" Value="OFF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <Border CornerRadius="3" Padding="5,1" Margin="4,0,0,0" Background="#1F2937">
                                                    <TextBlock Text="{Binding JustPlayText}" FontSize="9"
                                                               Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="{StaticResource Accent}" Margin="0,2,0,0">
                                                <Run Text="Match: "/>
                                                <Run Text="{Binding Match}"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                <TextBlock Text="{Binding SearchTypeText}" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Text=" · " FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Text="{Binding ServiceRef}" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BaseButton}" Margin="0,0,6,0"
                                                    Padding="8,5" FontSize="11" Content="✏ Edit"
                                                    Command="{Binding DataContext.EditAutoTimerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource DangerButton}"
                                                    Padding="8,5" FontSize="11" Content="Delete"
                                                    Command="{Binding DataContext.DeleteAutoTimerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Edit / Create Panel -->
            <Border Grid.Column="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16">
                        <!-- Panel header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Edit AutoTimer"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedAutoTimer}" Value="{x:Null}">
                                                <Setter Property="Text" Value="New AutoTimer"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Name -->
                        <TextBlock Text="Name" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                        <!-- Match string -->
                        <TextBlock Text="Match string (search text)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMatch, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                        <!-- Search Type -->
                        <TextBlock Text="Search type" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox SelectedIndex="{Binding EditSearchType}" Margin="0,0,0,12"
                                  Style="{StaticResource DarkComboBox}">
                            <ComboBoxItem Content="Contains"/>
                            <ComboBoxItem Content="Exact match"/>
                            <ComboBoxItem Content="Starts with"/>
                            <ComboBoxItem Content="Ends with"/>
                        </ComboBox>

                        <!-- Action -->
                        <TextBlock Text="Action" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox SelectedIndex="{Binding EditJustPlay}" Margin="0,0,0,12"
                                  Style="{StaticResource DarkComboBox}">
                            <ComboBoxItem Content="Record"/>
                            <ComboBoxItem Content="Zap only"/>
                        </ComboBox>

                        <!-- Avoid duplicates -->
                        <TextBlock Text="Avoid duplicate descriptions" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox SelectedIndex="{Binding EditAvoidDuplicates}" Margin="0,0,0,12"
                                  Style="{StaticResource DarkComboBox}">
                            <ComboBoxItem Content="Disabled"/>
                            <ComboBoxItem Content="On same day"/>
                            <ComboBoxItem Content="Always"/>
                            <ComboBoxItem Content="Same title and description"/>
                        </ComboBox>

                        <!-- Time range -->
                        <CheckBox Content="Restrict to a time window"
                                  IsChecked="{Binding EditTimeWindowEnabled}"
                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12" IsEnabled="{Binding EditTimeWindowEnabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="From time" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <controls:TimePicker Value="{Binding EditFrom, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="To time" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <controls:TimePicker Value="{Binding EditTo, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>

                        <!-- Channels (multiselect) -->
                        <TextBlock Text="Channels" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Empty state -->
                                <TextBlock Text="All channels (no restriction)" FontSize="12"
                                           Foreground="{StaticResource TextMuted}"
                                           Visibility="{Binding EditServiceRefs.Count, Converter={StaticResource ZeroToVisibility}}"/>
                                <!-- Chips -->
                                <ItemsControl ItemsSource="{Binding EditServiceRefs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BgHover}" CornerRadius="4"
                                                    Padding="8,4" Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="✕" Margin="6,0,0,0" Padding="2,0"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource TextMuted}" FontSize="10"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.RemoveSelectedChannelCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Style="{StaticResource BaseButton}" Padding="10,6" FontSize="12"
                                        HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Content="📺 Select channels…"
                                        Command="{Binding OpenChannelPickerCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Max duration -->
                        <TextBlock Text="Max duration in minutes (0 = unlimited)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditMaxDuration, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                        <!-- Enabled toggle -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox IsChecked="{Binding EditEnabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="AutoTimer enabled" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0"
                                    Content="💾 Save" Command="{Binding SaveAutoTimerCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                            <Button Style="{StaticResource BaseButton}" Padding="14,8"
                                    Content="Cancel" Command="{Binding CancelEditCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding AutoTimers.Count, Converter={StaticResource ZeroToVisibility}}">
            <TextBlock Text="🔁" FontSize="56" HorizontalAlignment="Center" Opacity="0.2"/>
            <TextBlock Text="No AutoTimers configured" Foreground="{StaticResource TextMuted}"
                       FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="Create rules to automatically record matching shows" Foreground="{StaticResource TextMuted}"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Center"
                    Padding="16,8" Margin="0,16,0,0" Content="+ Create first AutoTimer"
                    Command="{Binding NewAutoTimerCommand}"/>
        </StackPanel>

        <!-- Busy overlay -->
        <Border Grid.Row="1" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Channel picker modal — multiselect across bouquets, with search.
             Spans both rows so it sits above everything else in this view. -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#B0000000"
                Visibility="{Binding IsChannelPickerOpen, Converter={StaticResource BoolToVisibility}}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseChannelPickerCommand}"/>
            </Border.InputBindings>
            <Border Width="640" Height="520" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    MouseDown="ChannelPickerDialog_MouseDown">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Select channels" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Button Style="{StaticResource BaseButton}" Padding="8,4" FontSize="13"
                                Content="✕" HorizontalAlignment="Right"
                                Command="{Binding CloseChannelPickerCommand}"/>
                    </Grid>

                    <!-- Search -->
                    <TextBox Grid.Row="1" Margin="0,0,0,10"
                             Text="{Binding ChannelPickerSearch, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Tag="Search channels…"/>

                    <!-- Bouquets + channels -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Bouquet list -->
                        <ListBox Grid.Column="0" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 ItemsSource="{Binding PickerBouquets}"
                                 SelectedItem="{Binding PickerSelectedBouquet}"
                                 DisplayMemberPath="ServiceName">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Channel list for the selected bouquet, checkbox per row -->
                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PickerChannels}" Margin="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Cursor="Hand" Padding="8,6" CornerRadius="4">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.TogglePickerChannelCommand,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                  IsHitTestVisible="False"
                                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- In-dialog loading feedback: the page-wide busy overlay sits
                                 visually behind this picker dialog (it's earlier in the XAML),
                                 so without this the dialog would show nothing while a bouquet's
                                 channels (or the initial bouquet list) are loading. -->
                            <Border Background="{StaticResource BgCard}"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock Text="{Binding EditServiceRefsSummary}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource BaseButton}" Padding="12,7" Margin="0,0,8,0"
                                    Content="Clear all" Command="{Binding ClearSelectedChannelsCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Padding="14,7"
                                    Content="Done" Command="{Binding CloseChannelPickerCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
