<UserControl x:Class="DreamWin.Views.LiveTVView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:views="clr-namespace:DreamWin.Views"
             Background="{StaticResource BgDeep}">
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ChannelListColumn" Width="320" MinWidth="260"/>
            <ColumnDefinition x:Name="ChannelListGutterColumn" Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Channel List Panel ──────────────────────────── -->
        <Border x:Name="ChannelListPanel" Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Bouquet tabs -->
                    <RowDefinition Height="Auto"/>  <!-- Search -->
                    <RowDefinition Height="*"/>     <!-- Channel list -->
                </Grid.RowDefinitions>

                <!-- Bouquet selector (horizontal scroll) -->
                <DockPanel Grid.Row="0" Margin="8,8,8,0">
                    <Button Style="{StaticResource IconButton}" Width="34" Height="34" DockPanel.Dock="Left"
                            Content="◀" ToolTip="Scroll bouquets left" Click="ScrollBouquetsLeftClick"/>
                    <Button Style="{StaticResource IconButton}" Width="34" Height="34" DockPanel.Dock="Right"
                            Content="▶" ToolTip="Scroll bouquets right" Click="ScrollBouquetsRightClick"/>
                    <ScrollViewer x:Name="BouquetScrollViewer" HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled" Padding="0,0,0,0">
                        <ItemsControl ItemsSource="{Binding Bouquets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,4,0" Padding="10,5" FontSize="11"
                                            Command="{Binding DataContext.SelectBouquetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedBouquet"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding ServiceName}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Search -->
                <Border Grid.Row="1" Padding="8,6">
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Channel list -->
                <ListBox Grid.Row="2"
                         Style="{StaticResource DarkListBox}"
                         ItemContainerStyle="{StaticResource DarkListBoxItem}"
                         ItemsSource="{Binding Services}"
                         SelectedItem="{Binding SelectedService}"
                         x:Name="ChannelListBox"
                         SelectionChanged="ChannelList_SelectionChanged"
                         Padding="6,0,6,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Channel icon: use picon from receiver, fall back to hiding -->
                                <Border Grid.Column="0" Width="28" Height="28" Margin="0,0,10,0"
                                        CornerRadius="3" Background="#1A1D27">
                                    <Image Width="26" Height="26" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource PiconUrl}" TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                <Binding Path="ServiceReference"/>
                                                <Binding Path="DataContext.ActiveReceiver"
                                                         RelativeSource="{RelativeSource AncestorType={x:Type views:MainWindow}}"/>
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding ServiceName}" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- NOW PLAYING indicator -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="5,2" Margin="4,0"
                                        Background="{StaticResource Accent}" VerticalAlignment="Center">
                                    <TextBlock Text="▶ NOW" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.StreamingService"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SelectServiceCommand}"
                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                    </ListBox.InputBindings>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Video + Info Panel ──────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="NowNextSplitterRow" Height="4"/>
                <RowDefinition x:Name="NowNextRow" Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Video Player -->
            <Border Grid.Row="0" Background="Black">
                <!-- VLC VideoView: per LibVLCSharp.WPF airspace handling, all overlay content
                     (placeholder, controls) must be placed INSIDE VideoView, not as siblings,
                     otherwise the native video window breaks WPF hit-testing/focus for the
                     whole window. -->
                <vlc:VideoView x:Name="VideoView" Background="Black"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               MouseDoubleClick="VideoView_MouseDoubleClick">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>      <!-- Video + overlays -->
                            <RowDefinition Height="Auto"/>   <!-- Controlbar (auto-sized, collapses when hidden) -->
                        </Grid.RowDefinitions>

                        <!-- No stream placeholder -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityInverted}}">
                            <TextBlock Text="📺" FontSize="64" HorizontalAlignment="Center" Opacity="0.2"/>
                            <TextBlock Text="Select a channel to start watching"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Player Controls Overlay: always visible when playing normal, auto-hides in fullscreen -->
                        <Border x:Name="PlayerControlsOverlay" Grid.Row="1" Background="#CC000000"
                                Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Current / Next EPG -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedService.ServiceName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="{Binding CurrentEvent.TimeRange}"
                                                   FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding CurrentEvent.Title}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <!-- Progress bar -->
                                    <Border Height="3" Background="{StaticResource BgCard}" CornerRadius="2" Margin="0,4,0,0"
                                            Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                                        <Border HorizontalAlignment="Left" Background="{StaticResource Accent}"
                                                CornerRadius="2">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource ProgressToWidth}">
                                                    <Binding Path="CurrentEvent.ProgressPercent"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </StackPanel>

                                <!-- Controls -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding ChannelDownCommand}"
                                            Content="⏮" ToolTip="Previous channel"/>
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding ChannelUpCommand}"
                                            Content="⏭" ToolTip="Next channel"/>
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding PauseResumeCommand}"
                                            ToolTip="Pause / resume">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⏸"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                            <Setter Property="Text" Value="▶"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding ToggleMuteCommand}"
                                            ToolTip="Toggle mute">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="🔊"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                            <Setter Property="Text" Value="🔇"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Slider Width="80" VerticalAlignment="Center" Margin="0"
                                            Minimum="0" Maximum="100"
                                            Value="{Binding Volume}"
                                            Foreground="{StaticResource Accent}"/>
                                    <ComboBox Width="140" VerticalAlignment="Center" Margin="4,0"
                                              Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AudioTracks}"
                                              SelectedItem="{Binding SelectedAudioTrack}"
                                              DisplayMemberPath="Name"
                                              ToolTip="Audio track">
                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource BgCardColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource AccentColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding ToggleFullscreenCommand}"
                                            Content="⛶" ToolTip="Fullscreen"/>
                                    <!-- Signal quality -->
                                    <Border Margin="8,0,0,0" Padding="8,3" CornerRadius="4"
                                            Background="#1A1D27"
                                            Visibility="{Binding HasSignal, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="Signal strength (SNR / AGC)">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📶" FontSize="11" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SignalLabel}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Fullscreen: top-right EPG overlay (now/next for current channel only) -->
                        <Border x:Name="FullscreenEpgOverlay"
                                Grid.Row="0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="280" Background="#CC000000"
                                CornerRadius="0,0,0,8"
                                Visibility="Collapsed">
                            <StackPanel Margin="12,10,12,12">
                                <TextBlock Text="{Binding SelectedService.ServiceName}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Margin="0,6,0,0"
                                            Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                                    <TextBlock Text="NOW" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="{Binding CurrentEvent.Title}"
                                               FontSize="11" Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    <TextBlock Text="{Binding CurrentEvent.TimeRange}"
                                               FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                                <StackPanel Margin="0,6,0,0"
                                            Visibility="{Binding NextEvent, Converter={StaticResource NullToVisibility}}">
                                    <TextBlock Text="NEXT" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock Text="{Binding NextEvent.Title}"
                                               FontSize="11" Foreground="{StaticResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    <TextBlock Text="{Binding NextEvent.TimeRange}"
                                               FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Fullscreen: left-side channel list overlay -->
                        <Border x:Name="FullscreenChannelOverlay"
                                Grid.Row="0"
                                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                Width="240" Background="#E0000000"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="12,10" Background="#20FFFFFF">
                                    <TextBlock Text="CHANNELS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                </Border>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Services}"
                                         SelectedItem="{Binding SelectedService}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Width="26" Height="26" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource PiconUrl}"
                                                                      TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                            <Binding Path="ServiceReference"/>
                                                            <Binding Path="DataContext.ActiveReceiver"
                                                                     RelativeSource="{RelativeSource AncestorType={x:Type views:MainWindow}}"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>
                                                <TextBlock Grid.Column="1" Margin="6,0,0,0"
                                                           Text="{Binding ServiceName}"
                                                           FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            <Setter Property="Padding" Value="6,2"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Channel-switch mask: the actual VLC video surface is a native
                             child window two layers below WPF (see LibVLCSharp.WPF "airspace"
                             hack), so none of the Background="Black" properties above ever
                             reach it. When VLC's surface has nothing decoded yet — briefly
                             when switching channels — Windows paints that native window's
                             own default (white) background straight through, causing a
                             jarring white flash. This Border lives in the SAME top WPF overlay
                             layer as the controls above (i.e. it DOES reach the screen), and
                             PlayStream briefly shows it to mask that gap until the first frame
                             of the new stream actually arrives. -->
                        <Border x:Name="ChannelSwitchMask" Grid.Row="0" Grid.RowSpan="2" Background="Black"
                                Visibility="Collapsed" IsHitTestVisible="False"/>
                    </Grid>
                </vlc:VideoView>
            </Border>

            <GridSplitter x:Name="NowNextSplitter" Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" ResizeDirection="Rows"/>

            <!-- Now/Next Info Bar — compact, always visible when a channel is playing -->
            <Border x:Name="NowNextBar" Grid.Row="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="14,8"
                    Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>   <!-- Channel logo -->
                        <ColumnDefinition Width="*"/>    <!-- NOW -->
                        <ColumnDefinition Width="12"/>   <!-- Divider -->
                        <ColumnDefinition Width="*"/>    <!-- NEXT -->
                    </Grid.ColumnDefinitions>

                    <!-- Channel logo -->
                    <Image Grid.Column="0" Width="36" Height="36" Stretch="Uniform" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center">
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource PiconUrl}"
                                          TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                <Binding Path="StreamingService.ServiceReference"/>
                                <Binding Path="DataContext.ActiveReceiver"
                                         RelativeSource="{RelativeSource AncestorType={x:Type views:MainWindow}}"/>
                            </MultiBinding>
                        </Image.Source>
                    </Image>

                    <!-- NOW -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="NOW  " FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding CurrentEvent.Title}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   FontSize="10" Foreground="{StaticResource TextMuted}">
                            <Run Text="{Binding CurrentEvent.TimeRange, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding CurrentEvent.ShortDesc, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Column="2" Width="1" Background="{StaticResource BorderBrush}" Margin="6,2"/>

                    <!-- NEXT -->
                    <Grid Grid.Column="3"
                          Visibility="{Binding NextEvent, Converter={StaticResource NullToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="NEXT  " FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding NextEvent.Title}"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding NextEvent.TimeRange}"
                                   FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
