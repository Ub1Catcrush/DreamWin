<UserControl x:Class="DreamWin.Views.LiveTVView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="{StaticResource BgDeep}">
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ChannelListColumn" Width="320" MinWidth="260"/>
            <ColumnDefinition x:Name="ChannelListGutterColumn" Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Channel List Panel ──────────────────────────── -->
        <Border x:Name="ChannelListPanel" Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Bouquet tabs -->
                    <RowDefinition Height="Auto"/>  <!-- Search -->
                    <RowDefinition Height="*"/>     <!-- Channel list -->
                </Grid.RowDefinitions>

                <!-- Bouquet selector (horizontal scroll) -->
                <DockPanel Grid.Row="0" Margin="8,8,8,0">
                    <Button Style="{StaticResource IconButton}" Width="34" Height="34" DockPanel.Dock="Left"
                            Content="◀" ToolTip="Scroll bouquets left" Click="ScrollBouquetsLeftClick"/>
                    <Button Style="{StaticResource IconButton}" Width="34" Height="34" DockPanel.Dock="Right"
                            Content="▶" ToolTip="Scroll bouquets right" Click="ScrollBouquetsRightClick"/>
                    <ScrollViewer x:Name="BouquetScrollViewer" HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled" Padding="0,0,0,0">
                        <ItemsControl ItemsSource="{Binding Bouquets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,4,0" Padding="10,5" FontSize="11"
                                            Command="{Binding DataContext.SelectBouquetCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedBouquet"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding ServiceName}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Search -->
                <Border Grid.Row="1" Padding="8,6">
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Channel list -->
                <ListBox Grid.Row="2"
                         Style="{StaticResource DarkListBox}"
                         ItemContainerStyle="{StaticResource DarkListBoxItem}"
                         ItemsSource="{Binding Services}"
                         SelectedItem="{Binding SelectedService}"
                         x:Name="ChannelListBox"
                         SelectionChanged="ChannelList_SelectionChanged"
                         Padding="6,0,6,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Channel icon: use picon from receiver, fall back to hiding -->
                                <Border Grid.Column="0" Width="28" Height="28" Margin="0,0,10,0"
                                        CornerRadius="3" Background="#1A1D27">
                                    <Image Width="26" Height="26" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Source>
                                            <MultiBinding Converter="{StaticResource PiconUrl}" TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                <Binding Path="ServiceReference"/>
                                                <Binding Path="DataContext.ActiveReceiver"
                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Image.Source>
                                    </Image>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding ServiceName}" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- NOW PLAYING indicator -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="5,2" Margin="4,0"
                                        Background="{StaticResource Accent}" VerticalAlignment="Center">
                                    <TextBlock Text="▶ NOW" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ObjectsEqual}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.StreamingService"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SelectServiceCommand}"
                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                    </ListBox.InputBindings>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Video + Info Panel ──────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="NowNextSplitterRow" Height="6"/>
                <RowDefinition x:Name="NowNextRow" Height="200"/>
            </Grid.RowDefinitions>

            <!-- Video Player -->
            <Border Grid.Row="0" Background="Black">
                <!-- VLC VideoView: per LibVLCSharp.WPF airspace handling, all overlay content
                     (placeholder, controls) must be placed INSIDE VideoView, not as siblings,
                     otherwise the native video window breaks WPF hit-testing/focus for the
                     whole window. -->
                <vlc:VideoView x:Name="VideoView" Background="Black"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               MouseDoubleClick="VideoView_MouseDoubleClick">
                    <Grid>
                        <!-- No stream placeholder -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibilityInverted}}">
                            <TextBlock Text="📺" FontSize="64" HorizontalAlignment="Center" Opacity="0.2"/>
                            <TextBlock Text="Select a channel to start watching"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Player Controls Overlay: always visible when playing normal, auto-hides in fullscreen -->
                        <Border x:Name="PlayerControlsOverlay" VerticalAlignment="Bottom" Background="#CC000000"
                                Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Current / Next EPG -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedService.ServiceName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="{Binding CurrentEvent.TimeRange}"
                                                   FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding CurrentEvent.Title}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <!-- Progress bar -->
                                    <Border Height="3" Background="{StaticResource BgCard}" CornerRadius="2" Margin="0,4,0,0"
                                            Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                                        <Border HorizontalAlignment="Left" Background="{StaticResource Accent}"
                                                CornerRadius="2">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource ProgressToWidth}">
                                                    <Binding Path="CurrentEvent.ProgressPercent"/>
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </StackPanel>

                                <!-- Controls -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding ChannelDownCommand}"
                                            Content="⏮" ToolTip="Previous channel"/>
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding ChannelUpCommand}"
                                            Content="⏭" ToolTip="Next channel"/>
                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                            Command="{Binding PauseResumeCommand}"
                                            ToolTip="Pause / resume">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⏸"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                            <Setter Property="Text" Value="▶"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding ToggleMuteCommand}"
                                            ToolTip="Toggle mute">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="🔊"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                            <Setter Property="Text" Value="🔇"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Slider Width="80" VerticalAlignment="Center" Margin="0"
                                            Minimum="0" Maximum="100"
                                            Value="{Binding Volume}"
                                            Foreground="{StaticResource Accent}"/>
                                    <ComboBox Width="140" VerticalAlignment="Center" Margin="4,0"
                                              Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AudioTracks}"
                                              SelectedItem="{Binding SelectedAudioTrack}"
                                              DisplayMemberPath="Name"
                                              ToolTip="Audio track">
                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource BgCardColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource AccentColor}"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding ToggleFullscreenCommand}"
                                            Content="⛶" ToolTip="Fullscreen"/>
                                    <!-- Signal quality -->
                                    <Border Margin="8,0,0,0" Padding="8,3" CornerRadius="4"
                                            Background="#1A1D27"
                                            Visibility="{Binding HasSignal, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="Signal strength (SNR / AGC)">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📶" FontSize="11" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SignalLabel}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Fullscreen: right-side EPG overlay (now/next for nearby channels) -->
                        <Border x:Name="FullscreenEpgOverlay"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="340" Background="#E0000000"
                                Visibility="Collapsed"
                                Margin="0,0,0,0">
                            <StackPanel Margin="14,14,14,14">
                                <TextBlock Text="NOW ON AIR" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <!-- Current channel info -->
                                <Border Background="#22FFFFFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedService.ServiceName}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding CurrentEvent.Title}"
                                                   FontSize="12" Foreground="{StaticResource Accent}"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding CurrentEvent.TimeRange}"
                                                   FontSize="10" Foreground="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding NextEvent.Title, StringFormat='Next: {0}'}"
                                                   FontSize="10" Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding NextEvent, Converter={StaticResource NullToVisibility}}"/>
                                    </StackPanel>
                                </Border>
                                <!-- Nearby channels now/next -->
                                <ItemsControl ItemsSource="{Binding NearbyNowNext}"
                                              MaxHeight="400">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Margin="0,2" CornerRadius="4"
                                                    Background="#15FFFFFF">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ServiceName}"
                                                               FontSize="10" Foreground="{StaticResource TextMuted}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding NowTitle}"
                                                                   FontSize="11" Foreground="{StaticResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding NowTime}"
                                                                   FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Fullscreen: left-side channel list overlay -->
                        <Border x:Name="FullscreenChannelOverlay"
                                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                Width="240" Background="#E0000000"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="12,10" Background="#20FFFFFF">
                                    <TextBlock Text="CHANNELS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                </Border>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Services}"
                                         SelectedItem="{Binding SelectedService}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Width="26" Height="26" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource PiconUrl}"
                                                                      TargetNullValue="{x:Null}" FallbackValue="{x:Null}">
                                                            <Binding Path="ServiceReference"/>
                                                            <Binding Path="DataContext.ActiveReceiver"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>
                                                <TextBlock Grid.Column="1" Margin="6,0,0,0"
                                                           Text="{Binding ServiceName}"
                                                           FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            <Setter Property="Padding" Value="6,2"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </vlc:VideoView>
            </Border>

            <GridSplitter x:Name="NowNextSplitter" Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" ResizeDirection="Rows"/>

            <!-- Now/Next Info Bar -->
            <Border x:Name="NowNextBar" Grid.Row="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,10"
                    Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Now -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NOW" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding CurrentEvent.Title}"
                                   FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentEvent.TimeRange}"
                                   FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="{Binding CurrentEvent.ShortDesc}"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Separator Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}" Margin="16,0"/>

                    <!-- Next -->
                    <StackPanel Grid.Column="2"
                                Visibility="{Binding NextEvent, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="NEXT" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding NextEvent.Title}"
                                   FontSize="13" Foreground="{StaticResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding NextEvent.TimeRange}"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
