<UserControl x:Class="DreamWin.Views.TimersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DreamWin.Controls"
             Background="{StaticResource BgDeep}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Timers" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="{Binding Timers.Count, StringFormat='{}{0} scheduled'}"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource BaseButton}" Padding="12,8" Margin="0,0,8,0"
                            Content="↺ Refresh" Command="{Binding LoadCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource BaseButton}" Padding="12,8" Margin="0,0,8,0"
                            Content="🗑 Clean up" Command="{Binding CleanupExpiredTimersCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            ToolTip="Remove all completed/expired timers"/>
                    <Button Style="{StaticResource AccentButton}" Padding="14,8"
                            Content="+ New Timer" Command="{Binding NewTimerCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Timer List -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Error banner -->
                    <Border Margin="12,12,12,0" Padding="12,8" CornerRadius="6"
                            Background="#332E3A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentRed}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Timers}" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="8"
                                        Background="{StaticResource BgCard}"
                                        BorderThickness="1">
                                    <Border.BorderBrush>
                                        <Binding Path="State" Converter="{StaticResource TimerStateToColor}"/>
                                    </Border.BorderBrush>
                                    <Grid Margin="14,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- State indicator -->
                                        <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0"
                                                Background="{Binding State, Converter={StaticResource TimerStateToColor}}"/>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#EF4444" Opacity="0.2"/>
                                                    </Border.Background>
                                                    <TextBlock Text="REC" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentRed}"/>
                                                </Border>
                                                <Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                        Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#6B7280" Opacity="0.2"/>
                                                    </Border.Background>
                                                    <TextBlock Text="OFF" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource TextMuted}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ServiceName}"
                                                       FontSize="11" Foreground="{StaticResource Accent}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding TimeRange}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,1,0,0"/>
                                            <TextBlock Text="{Binding StateText}"
                                                       FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BaseButton}" Margin="0,0,6,0"
                                                    Padding="8,5" FontSize="11" Content="✏ Edit"
                                                    Command="{Binding DataContext.EditTimerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource BaseButton}" Margin="0,0,6,0"
                                                    Padding="8,5" FontSize="11"
                                                    Command="{Binding DataContext.ToggleTimerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Content>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Disable"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                        <Setter Property="Text" Value="Enable"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button.Content>
                                            </Button>
                                            <Button Style="{StaticResource DangerButton}"
                                                    Padding="8,5" FontSize="11" Content="Delete"
                                                    Command="{Binding DataContext.DeleteTimerCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Create / Edit Timer Panel -->
            <Border Grid.Column="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16">
                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Edit Timer"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTimer}" Value="{x:Null}">
                                            <Setter Property="Text" Value="New Timer"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Timer Name -->
                        <TextBlock Text="Timer name" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                        <!-- Service name -->
                        <TextBlock Text="Channel name" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditServiceName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

                        <!-- Channel -->
                        <TextBlock Text="Channel" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding EditServiceName}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EditServiceName}" Value="">
                                                    <Setter Property="Text" Value="No channel selected"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Style="{StaticResource BaseButton}" Padding="10,6" FontSize="12"
                                        HorizontalAlignment="Left"
                                        Content="📺 Select channel…"
                                        Command="{Binding OpenChannelPickerCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Date -->
                        <TextBlock Text="Date" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding EditBeginDate}"
                                    Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                    BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                        <!-- Begin / End Time -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start time" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <controls:TimePicker Value="{Binding EditBeginTime, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End time" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <controls:TimePicker Value="{Binding EditEndTime, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>

                        <!-- After event -->
                        <TextBlock Text="After event" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox SelectedIndex="{Binding EditAfterEvent}" Margin="0,0,0,20"
                                  Style="{StaticResource DarkComboBox}">
                            <ComboBoxItem Content="Nothing"/>
                            <ComboBoxItem Content="Standby"/>
                            <ComboBoxItem Content="Deep standby"/>
                            <ComboBoxItem Content="Auto"/>
                        </ComboBox>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0"
                                    Content="💾 Save" Command="{Binding SaveTimerCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                            <Button Style="{StaticResource BaseButton}" Padding="14,8"
                                    Content="Cancel" Command="{Binding CancelEditCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Timers.Count, Converter={StaticResource ZeroToVisibility}}">
            <TextBlock Text="⏺" FontSize="56" HorizontalAlignment="Center" Opacity="0.2"/>
            <TextBlock Text="No timers scheduled" Foreground="{StaticResource TextMuted}"
                       FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="Add timers from the EPG guide or create one manually" Foreground="{StaticResource TextMuted}"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Center"
                    Padding="16,8" Margin="0,16,0,0" Content="+ New Timer"
                    Command="{Binding NewTimerCommand}"/>
        </StackPanel>

        <!-- Busy overlay -->
        <Border Grid.Row="1" Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Channel picker modal (single-select) -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#B0000000"
                Visibility="{Binding IsChannelPickerOpen, Converter={StaticResource BoolToVisibility}}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseChannelPickerCommand}"/>
            </Border.InputBindings>
            <Border Width="640" Height="520" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    MouseDown="ChannelPickerDialog_MouseDown">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Select a channel" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <Button Style="{StaticResource BaseButton}" Padding="8,4" FontSize="13"
                                Content="✕" HorizontalAlignment="Right"
                                Command="{Binding CloseChannelPickerCommand}"/>
                    </Grid>

                    <!-- Search -->
                    <TextBox Grid.Row="1" Margin="0,0,0,10"
                             Text="{Binding ChannelPickerSearch, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Tag="Search channels…"/>

                    <!-- Bouquets + channels -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" Background="{StaticResource BgCard}"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 ItemsSource="{Binding PickerBouquets}"
                                 SelectedItem="{Binding PickerSelectedBouquet}"
                                 DisplayMemberPath="ServiceName">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PickerChannels}" Margin="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Cursor="Hand" Padding="8,6" CornerRadius="4">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectPickerChannelCommand,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               Foreground="{StaticResource TextPrimary}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- In-dialog loading feedback — see AutoTimersView's identical
                                     comment: the page-wide busy overlay sits behind this dialog. -->
                                <Border Background="{StaticResource BgCard}"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
