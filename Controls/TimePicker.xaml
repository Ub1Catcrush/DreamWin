<UserControl x:Class="DreamWin.Controls.TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="120" d:DesignHeight="32">
    <!--
        A proper time picker: two dropdowns (hour 00-23, minute 00-59) that
        together back a single bindable "HH:mm" string Value property — so call
        sites that used to bind a TextBox directly to an "HH:mm" string property
        can swap in this control with no view-model changes at all.
    -->
    <StackPanel x:Name="RootPanel" Orientation="Horizontal">
        <ComboBox x:Name="HourCombo" Width="58"
                  Style="{StaticResource DarkComboBox}"
                  ItemsSource="{Binding HourOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedItem="{Binding SelectedHour, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <TextBlock Text=":" FontSize="16" Margin="6,0" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondary}"/>
        <ComboBox x:Name="MinuteCombo" Width="58"
                  Style="{StaticResource DarkComboBox}"
                  ItemsSource="{Binding MinuteOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedItem="{Binding SelectedMinute, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </StackPanel>
</UserControl>
